{{- /* ===================================================================
   _nestedFromResourceData: extract nested (List/Set of objects) field
   Data: fieldInfo (with .NestedFields, .NestedStructName, .IsSet)
   =================================================================== */ -}}
{{- define "_nestedFromResourceData" -}}
			if v, ok := d.GetOk({{ printf "%q" .TFName }}); ok {
				var items []v1alpha1.{{ .NestedStructName }}
				var list []interface{}
{{- if .IsSet }}
				if s, ok := v.(*sdkschema.Set); ok {
					list = s.List()
				}
{{- else }}
				list, _ = v.([]interface{})
{{- end }}
				for _, raw := range list {
					item := v1alpha1.{{ .NestedStructName }}{}
{{- if hasScalarNestedFields .NestedFields }}
					m, _ := raw.(map[string]interface{})
{{- range .NestedFields }}
{{- if and (not .NestedFields) (isScalar .GoType) }}
{{- if eq .GoType "string" }}
					if val, ok := m[{{ printf "%q" .TFName }}].(string); ok {
						item.{{ .GoName }} = val
					}
{{- else if eq .GoType "*string" }}
					if val, ok := m[{{ printf "%q" .TFName }}].(string); ok {
						item.{{ .GoName }} = &val
					}
{{- else if eq .GoType "int64" }}
					if val, ok := m[{{ printf "%q" .TFName }}].(int); ok {
						v := int64(val)
						item.{{ .GoName }} = v
					}
{{- else if eq .GoType "*int64" }}
					if val, ok := m[{{ printf "%q" .TFName }}].(int); ok {
						v := int64(val)
						item.{{ .GoName }} = &v
					}
{{- else if eq .GoType "bool" }}
					if val, ok := m[{{ printf "%q" .TFName }}].(bool); ok {
						item.{{ .GoName }} = val
					}
{{- else if eq .GoType "*bool" }}
					if val, ok := m[{{ printf "%q" .TFName }}].(bool); ok {
						item.{{ .GoName }} = &val
					}
{{- else if eq .GoType "float64" }}
					if val, ok := m[{{ printf "%q" .TFName }}].(float64); ok {
						item.{{ .GoName }} = val
					}
{{- else if eq .GoType "*float64" }}
					if val, ok := m[{{ printf "%q" .TFName }}].(float64); ok {
						item.{{ .GoName }} = &val
					}
{{- end }}
{{- end }}
{{- end }}
{{- else }}
					_ = raw
{{- end }}
					items = append(items, item)
				}
				cr.Status.AtProvider.{{ .GoName }} = items
			}
{{ end -}}

