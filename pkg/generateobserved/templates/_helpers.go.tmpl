{{- /* ===================================================================
   _connectionDetails: emit the ConnectionDetailsFn field
   Data: connectionDetailsData{KindName string, Scalars []fieldInfo}
   =================================================================== */ -}}
{{- define "_connectionDetails" -}}
	ConnectionDetailsFn: func(mg resource.Managed) managed.ConnectionDetails {
		cr := mg.(*v1alpha1.{{ .KindName }})
		cd := managed.ConnectionDetails{}
		if id := meta.GetExternalName(cr); id != "" {
			cd["id"] = []byte(id)
		}
{{- range .Scalars }}
{{- if eq .GoType "*string" }}
		if cr.Status.AtProvider.{{ .GoName }} != nil {
			cd[{{ printf "%q" .TFName }}] = []byte(*cr.Status.AtProvider.{{ .GoName }})
		}
{{- else if eq .GoType "string" }}
		if cr.Status.AtProvider.{{ .GoName }} != "" {
			cd[{{ printf "%q" .TFName }}] = []byte(cr.Status.AtProvider.{{ .GoName }})
		}
{{- else if eq .GoType "*int64" }}
		if cr.Status.AtProvider.{{ .GoName }} != nil {
			cd[{{ printf "%q" .TFName }}] = []byte(strconv.FormatInt(*cr.Status.AtProvider.{{ .GoName }}, 10))
		}
{{- else if eq .GoType "int64" }}
		cd[{{ printf "%q" .TFName }}] = []byte(strconv.FormatInt(cr.Status.AtProvider.{{ .GoName }}, 10))
{{- else if eq .GoType "*float64" }}
		if cr.Status.AtProvider.{{ .GoName }} != nil {
			cd[{{ printf "%q" .TFName }}] = []byte(strconv.FormatFloat(*cr.Status.AtProvider.{{ .GoName }}, 'f', -1, 64))
		}
{{- else if eq .GoType "float64" }}
		cd[{{ printf "%q" .TFName }}] = []byte(strconv.FormatFloat(cr.Status.AtProvider.{{ .GoName }}, 'f', -1, 64))
{{- else if eq .GoType "*bool" }}
		if cr.Status.AtProvider.{{ .GoName }} != nil {
			cd[{{ printf "%q" .TFName }}] = []byte(strconv.FormatBool(*cr.Status.AtProvider.{{ .GoName }}))
		}
{{- else if eq .GoType "bool" }}
		cd[{{ printf "%q" .TFName }}] = []byte(strconv.FormatBool(cr.Status.AtProvider.{{ .GoName }}))
{{- end }}
{{- end }}
		return cd
	},
{{ end -}}

